# =============================================================
# .env.example — Vorlage für Umgebungsvariablen
#
# ANLEITUNG:
#   1. Diese Datei kopieren: cp .env.example .env
#   2. Alle "changeme"-Werte durch sichere Werte ersetzen
#   3. Die .env-Datei NIEMALS ins Git committen!
# =============================================================

# --- PostgreSQL Datenbank ---
# Benutzername für die Postgres-Datenbank
POSTGRES_USER=budgetbook

# Passwort für den Postgres-Benutzer — bitte ändern!
POSTGRES_PASSWORD=changeme

# Name der Datenbank, die angelegt wird
POSTGRES_DB=budgetbook

# Vollständige Verbindungs-URL für die App.
# Im Docker-Netzwerk heißt der DB-Container "db" (siehe docker-compose.yml).
# Format: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+psycopg2://budgetbook:changeme@db:5432/budgetbook

# --- App ---
# Umgebung: "development" oder "production"
ENVIRONMENT=development

# Geheimer Schlüssel für Sessions/Tokens — bitte durch langen Zufallswert ersetzen!
# Tipp: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=changeme-replace-with-a-long-random-string

# --- Initiales Admin-Konto ---
# Wird beim ersten Start automatisch angelegt (falls noch kein Admin existiert).
# Danach haben diese Werte keinen Einfluss mehr auf den Login.
#
# ADMIN_PASSWORD kann entweder ein Klartext-Passwort sein (wird beim Start automatisch gehasht)
# ODER ein bereits fertiger Argon2id-Hash (beginnt mit "$argon2id$...").
#
# Argon2id-Hash selbst erzeugen (empfohlen für erhöhte Sicherheit):
#   docker compose run --rm backend python tools/hash_password.py
#
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=bitte-ein-starkes-passwort-waehlen
